    "publisher": "Wan-AI / Alibaba Group (Hangzhou, CN)",
    "architecture": "Diffusion Transformer (T2V, MoE, 2x14B experts, boundary_ratio=0.875)",
    "params": "27B total (2x 14B MoE experts, 14B active)",
    "text_encoders": ["uMT5-XXL (multilingual)"],
    "quantization": "BF16 default, FP8 optional (DIFFUSERS_WAN22_QUANTIZE=fp8)",
